{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "src", ".next"]
}
